# Database Configuration
POSTGRES_USER=mixarr
POSTGRES_PASSWORD=mixarrpass
POSTGRES_DB=mixarrdb
DATABASE_URL=postgresql://mixarr:mixarrpass@db:5432/mixarrdb?schema=public

# Plex Authentication
# Generate a random UUID for the client identifier (e.g. using uuidgen)
PLEX_CLIENT_IDENTIFIER=your-random-uuid-here
PLEX_PRODUCT_NAME="Mixarr Playlist Curator"
PLEX_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Popularity Providers (deezer, lastfm, spotify)
DEFAULT_POPULARITY_PROVIDER=deezer
POPULARITY_REFRESH_DAYS=30

# Track Genre Providers
# Lookup order defaults to Deezer -> Discogs -> MusicBrainz -> optional Spotify -> Last.fm fallback.
# Disabled providers in the list are skipped.
TRACK_TAG_PROVIDER_ORDER=deezer,discogs,musicbrainz,spotify,lastfm
TRACK_TAG_MAX_TAGS=8

# Deezer album genre tags. No API key is needed.
DEEZER_TAGS_ENABLED=1

# Discogs genre/style tags.
# Disabled by default because Discogs API content has attribution/cache terms.
# For public database lookups, register an app and set Consumer Key/Secret.
# Full OAuth 1.0a flow endpoints, if you choose to generate access tokens:
# Request Token URL: https://api.discogs.com/oauth/request_token
# Authorize URL: https://www.discogs.com/oauth/authorize
# Access Token URL: https://api.discogs.com/oauth/access_token
DISCOGS_TAGS_ENABLED=0
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
DISCOGS_ACCESS_TOKEN=
DISCOGS_ACCESS_TOKEN_SECRET=
DISCOGS_USER_AGENT=Mixarr/1.0
# Minimum spacing between Discogs API calls in milliseconds. Discogs's
# authenticated rate cap is 60 req/min; 1100ms (~55 req/min) keeps us
# safely under it. Set to 0 to disable the throttle (not recommended).
DISCOGS_RATE_LIMIT_MS=1100

# MusicBrainz genre/tags. No API key is needed, but a meaningful User-Agent
# is required and the public API allows no more than one request per second.
MUSICBRAINZ_TAGS_ENABLED=1
MUSICBRAINZ_USER_AGENT="Mixarr/1.0 (your-email@example.com)"
MUSICBRAINZ_MIN_REQUEST_INTERVAL_MS=1100

# Last.fm
# Used by popularity fallback and only as the final Track Genres fallback.
LASTFM_API_KEY=
LASTFM_TAG_FALLBACK_ENABLED=1

# Last.fm autocorrect (0 = off, 1 = on; default off)
# When enabled, Last.fm corrects misspelled / mis-cased artist & track
# names server-side before looking up the record. Catches case drift,
# accent loss ("Beyonce" vs "Beyoncé"), and "feat." / "ft." / "featuring"
# variations - typically lifts tag hit rate significantly when Plex
# metadata isn't already canonicalized.
#
# Tradeoff: occasional false positives on obscure tracks with similar
# names (you'll get the popular track's tags instead of nothing).
# The metric `mixarr_lastfm_autocorrections_total` (broken down by
# field=artist|track|both) makes the rate of corrections visible on the
# Grafana dashboard so you can spot pathological cases.
LASTFM_AUTOCORRECT=0

# Spotify
# Used for popularity/audio features. Spotify artist genres are optional for
# Track Genres and are disabled by default because the artist genre field is
# deprecated in Spotify's Web API docs and subject to Spotify metadata terms.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_TAGS_ENABLED=0

# Playlist Configuration
MAX_PLAYLIST_SIZE=5000

# Local BPM Backfill
# Deezer is tried first, then Plex audio is sampled with ffmpeg and analyzed with aubio.
# Local analysis samples 30s-90s, the middle window, and the last-third window.
# Batch limits are configured in Settings > Sync Controls.
LOCAL_BPM_SAMPLE_SECONDS=60
LOCAL_BPM_RETRY_DAYS=14
LOCAL_BPM_CONFIDENCE_THRESHOLD=0.75
LOCAL_BPM_FFMPEG_PATH=ffmpeg
LOCAL_BPM_AUBIO_PATH=aubio

# Background Scheduler
# Schedule for autonomous nightly library & metadata sync (Cron syntax)
# Default is 3:00 AM every day
SYNC_CRON_SCHEDULE="0 3 * * *"

# Hard wall-clock deadline (in milliseconds) for the nightly pipeline.
# If a slow / hung step exceeds this, the scheduler aborts so the next
# nightly tick can run cleanly. Default 6h.
SYNC_MAX_PIPELINE_MS=21600000

# Prometheus Metrics
# Port for the /metrics endpoint. Set to 0 (default) to disable the
# metrics server entirely. If you change this, you'll also need to map
# the port in your docker-compose.yml to make it reachable from the host.
METRICS_PORT=0
