# Database Configuration
POSTGRES_USER=mixarr
POSTGRES_PASSWORD=mixarrpass
POSTGRES_DB=mixarrdb
DATABASE_URL=postgresql://mixarr:mixarrpass@db:5432/mixarrdb?schema=public

# Plex Authentication
# Generate a random UUID for the client identifier (e.g. using uuidgen)
PLEX_CLIENT_IDENTIFIER=your-random-uuid-here
PLEX_PRODUCT_NAME="Mixarr Playlist Curator"
PLEX_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Popularity Providers (deezer, lastfm, spotify)
DEFAULT_POPULARITY_PROVIDER=deezer
POPULARITY_REFRESH_DAYS=30

# Last.fm
# Used by the popularity engine as a fallback ranking source AND by the
# track-tag engine for genre / mood tags. Last.fm is currently the only
# tag source, so leaving this blank will keep the Track Genres engine
# permanently stuck at 0% (every track gets a "no tags" marker row).
# Get a key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Last.fm autocorrect (0 = off, 1 = on; default off)
# When enabled, Last.fm corrects misspelled / mis-cased artist & track
# names server-side before looking up the record. Catches case drift,
# accent loss ("Beyonce" vs "Beyoncé"), and "feat." / "ft." / "featuring"
# variations - typically lifts tag hit rate significantly when Plex
# metadata isn't already canonicalized.
#
# Tradeoff: occasional false positives on obscure tracks with similar
# names (you'll get the popular track's tags instead of nothing).
LASTFM_AUTOCORRECT=0

# Spotify (Optional, used as fallback if others fail)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Playlist Configuration
MAX_PLAYLIST_SIZE=5000

# Background Scheduler
# Schedule for autonomous nightly library & metadata sync (Cron syntax)
# Default is 3:00 AM every day
SYNC_CRON_SCHEDULE="0 3 * * *"
