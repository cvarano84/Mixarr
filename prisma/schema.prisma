generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  plexId        Int            @unique
  username      String
  email         String?
  thumb         String?
  accessToken   String
  defaultServerId  String?
  defaultLibraryId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  servers       Server[]
  playlistRules PlaylistRule[]
  playlistHistory PlaylistHistory[]
  blockedTracks BlockedTrack[]
}

model Server {
  id                String    @id @default(uuid())
  machineIdentifier String    @unique
  name              String
  uri               String
  accessToken       String
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  libraries         Library[]
  playlistRules     PlaylistRule[]
  playlistHistory   PlaylistHistory[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Library {
  id        String     @id @default(uuid())
  plexId    String
  serverId  String
  name      String
  type      String
  server    Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  artists   Artist[]
  albums    Album[]
  tracks    Track[]
  syncLogs  SyncLog[]
  playlistRules PlaylistRule[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([serverId, plexId])
}

model Artist {
  id         String   @id @default(uuid())
  plexId     String
  libraryId  String
  title      String
  summary    String?
  thumb      String?
  addedAt    DateTime?
  updatedAt  DateTime?
  viewCount  Int      @default(0)
  lastViewedAt DateTime?
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  albums     Album[]
  tracks     Track[]
  tags       Tag[]    @relation("ArtistTags")

  @@unique([libraryId, plexId])
}

model Album {
  id         String   @id @default(uuid())
  plexId     String
  libraryId  String
  artistId   String
  title      String
  summary    String?
  thumb      String?
  year       Int?
  addedAt    DateTime?
  updatedAt  DateTime?
  viewCount  Int      @default(0)
  lastViewedAt DateTime?
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  artist     Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks     Track[]
  tags       Tag[]    @relation("AlbumTags")

  @@unique([libraryId, plexId])
}

model Track {
  id         String   @id @default(uuid())
  plexId     String
  ratingKey  String
  libraryId  String
  albumId    String
  artistId   String
  title      String
  duration   Int?
  trackIndex Int?
  rating     Float?
  contentRating String?
  normalizedTitle String?
  isExplicit Boolean @default(false)
  isLive     Boolean @default(false)
  isRemaster Boolean @default(false)
  isHoliday  Boolean @default(false)
  isIntroOutro Boolean @default(false)
  viewCount  Int      @default(0)
  lastViewedAt DateTime?
  addedAt    DateTime?
  updatedAt  DateTime?
  tagsSyncedAt DateTime?
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  album      Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  artist     Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tags       Tag[]    @relation("TrackTags")
  popularity Popularity?
  audioFeature AudioFeature?
  blockedBy  BlockedTrack[]

  @@unique([libraryId, plexId])
}

model Tag {
  id       String   @id @default(uuid())
  type     String   // genre, mood, style, country, decade
  name     String
  artists  Artist[] @relation("ArtistTags")
  albums   Album[]  @relation("AlbumTags")
  tracks   Track[]  @relation("TrackTags")

  @@unique([type, name])
}

model Popularity {
  id          String   @id @default(uuid())
  trackId     String   @unique
  provider    String   // deezer, lastfm, spotify
  score       Float    // Normalized score 0-100 or 0-1M
  confidence  Float?
  matchedArtist String?
  matchedTitle  String?
  lastUpdated DateTime @default(now())
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model AudioFeature {
  id           String   @id @default(uuid())
  trackId      String   @unique
  energy       Float?
  valence      Float?
  danceability Float?
  tempo        Float?
  source       String?
  confidence   Float?
  tempoSource  String?
  tempoConfidence Float?
  lastUpdated  DateTime @default(now())
  track        Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model BlockedTrack {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model PlaylistRule {
  id                String    @id @default(uuid())
  userId            String
  serverId          String?
  libraryId         String?
  name              String
  rulesJson         String    // JSON string of builder filters
  optionsJson       String    @default("{}")
  limit             Int       @default(50)
  autoRefresh       Boolean   @default(false)
  plexPlaylistId    String?
  lastRefreshedAt   DateTime?
  lastRefreshStatus String?
  lastRefreshError  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  server            Server?   @relation(fields: [serverId], references: [id], onDelete: SetNull)
  library           Library?  @relation(fields: [libraryId], references: [id], onDelete: SetNull)
  history           PlaylistHistory[]
}

model PlaylistHistory {
  id              String   @id @default(uuid())
  userId          String
  playlistRuleId  String?
  serverId        String?
  name            String
  rulesJson       String
  optionsJson     String   @default("{}")
  trackCount      Int
  plexPlaylistId  String?
  status          String
  error           String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlistRule    PlaylistRule? @relation(fields: [playlistRuleId], references: [id], onDelete: SetNull)
  server          Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
}

model SyncLog {
  id        String   @id @default(uuid())
  libraryId String
  status    String   // in_progress, success, failed
  startedAt DateTime @default(now())
  endedAt   DateTime?
  error     String?
  library   Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
}

// Generic key/value store for state that must survive container restarts.
// Currently used for Spotify's rate-limit backoff: when the API tells us to
// wait N hours, we store the absolute expiry timestamp so a container
// restart can't accidentally "forget" the backoff and immediately hammer
// Spotify again (which is what caused the 1,698 rate-limit log lines in
// the original captured trace).
model SystemState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
